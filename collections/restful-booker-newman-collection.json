  "item": [
    {
      "name": "GET All Bookings",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is JSON\", function () {\r",
              "    pm.response.to.have.header(\"Content-Type\", \"application/json; charset=utf-8\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Each item has a bookingid\", function () {\r",
              "    const json = pm.response.json();\r",
              "    json.forEach(function(booking) {\r",
              "        pm.expect(booking).to.have.property(\"bookingid\");\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is under 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/booking",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "booking"
          ]
        }
      },
      "response": []
    },
    {
      "name": "POST Create a Booking - CSV data",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is under 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains bookingid\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.have.property(\"bookingid\");\r",
              "    pm.expect(json.bookingid).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "pm.test(\"Schema is valid\", function () {\r",
              "    const json = pm.response.json().booking;\r",
              "    pm.expect(json).to.have.property(\"firstname\").that.is.a(\"string\");\r",
              "    pm.expect(json).to.have.property(\"lastname\").that.is.a(\"string\");\r",
              "    pm.expect(json).to.have.property(\"totalprice\").that.is.a(\"number\");\r",
              "    pm.expect(json).to.have.property(\"depositpaid\").that.is.a(\"boolean\");\r",
              "    pm.expect(json).to.have.property(\"bookingdates\").that.is.an(\"object\");\r",
              "    pm.expect(json).to.have.property(\"additionalneeds\").that.is.a(\"string\");\r",
              "});\r",
              "\r",
              "pm.test(\"Booking data matches what was sent\", function () {\r",
              "    const json = pm.response.json().booking;\r",
              "    pm.expect(json.firstname).to.eql(pm.iterationData.get(\"firstname\"));\r",
              "    pm.expect(json.lastname).to.eql(pm.iterationData.get(\"lastname\"));\r",
              "    pm.expect(json.totalprice).to.eql(Number(pm.iterationData.get(\"totalprice\")));\r",
              "});\r",
              "\r",
              "// Chain the new bookingid into future requests\r",
              "const newBookingId = pm.response.json().bookingid;\r",
              "pm.collectionVariables.set(\"bookingId\", newBookingId);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
