  "item": [
    {
      "name": "301 - Status Code Bug Documentation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test 1: Confirm the status code is actually 301",
              "pm.test(\"Status code is 301 (not redirecting as expected)\", function () {",
              "    pm.response.to.have.status(301);",
              "});",
              "",
              "// Test 2: Confirm the Location header is missing (the broken part)",
              "pm.test(\"Location header is missing — known bug\", function () {",
              "    const locationHeader = pm.response.headers.get(\"Location\");",
              "    pm.expect(locationHeader).to.be.undefined;",
              "});",
              "",
              "// Test 3: Confirm a body was returned (unusual for a redirect)",
              "pm.test(\"Response has a body despite being a redirect — known bug\", function () {",
              "    pm.expect(pm.response.text()).to.include(\"This page returned a 301 status code\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://the-internet.herokuapp.com/status_codes/301",
          "protocol": "https",
          "host": [
            "the-internet",
            "herokuapp",
            "com"
          ],
          "path": [
            "status_codes",
            "301"
          ]
        },
        "description": "This is a GET request and it is used to \"get\" data from an endpoint. There is no request body for a GET request, but you can use query parameters to help specify the resource you want data on (e.g., in this request, we have `id=1`).\n\nA successful GET response will have a `200 OK` status, and should include some kind of response body - for example, HTML web content or JSON data."
      },
      "response": []
    },
