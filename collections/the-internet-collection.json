          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"No WWW-Authenticate header on success\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"WWW-Authenticate\")).to.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains success message\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"Congratulations\");\r",
              "});"
